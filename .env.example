DATABASE_URL="postgresql://postgres:postgres@localhost:${POSTGRES_PORT:-5432}/player_auction"
AUTH_SECRET="change-me-to-a-random-string"
AUTH_URL="http://localhost:3000"
CRICAPI_KEY="your-cricketdata-org-api-key"
# Optional default fantasy ruleset id for match_points (per-league override in UI)
CRICAPI_FANTASY_RULESET_ID=""

# Scoring poller: timezone and daily window (America/Los_Angeles for IPL PT)
SCORING_POLL_TZ="America/Los_Angeles"
SCORING_POLL_WINDOW_START="03:00"
SCORING_POLL_WINDOW_END="16:00"
# Milliseconds between polls when outside the window (default 1h)
SCORING_POLL_IDLE_OUTSIDE_WINDOW_MS="3600000"

# Bearer secret for POST /api/leagues/:id/matches/reconcile-scrape (cron / scripts)
SCORING_SYNC_SECRET=""
