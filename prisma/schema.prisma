generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  memberships    LeagueMember[]
  bids           Bid[]
  createdLeagues League[]       @relation("LeagueCreator")
  tradesFrom     Trade[]        @relation("TradeFrom")
  tradesTo       Trade[]        @relation("TradeTo")
}

// ─── League ──────────────────────────────────────────────────────────────────

model League {
  id            String      @id @default(cuid())
  name          String
  inviteCode    String      @unique @default(cuid())
  description   String?
  phase         LeaguePhase @default(SETUP)
  budget        Int         @default(10000000)
  scoringTopN   Int         @default(7)
  overseasCap   Int         @default(4)
  sheetUrl      String?
  scoringRules  Json?
  currentPot          String?
  currentPlayer       String?
  currentPlayerIndex  Int         @default(0)
  createdById   String
  createdBy     User        @relation("LeagueCreator", fields: [createdById], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  minBidIncrement  Int     @default(10000000)
  cricapiSeriesId  String?
  cricapiFantasyRulesetId String?

  members LeagueMember[]
  players Player[]
  bids    Bid[]
  matches LeagueMatch[]
  trades  Trade[]
  teams   Team[]
}

enum LeaguePhase {
  SETUP
  AUCTION_ACTIVE
  AUCTION_PAUSED
  AUCTION_COMPLETE
  LEAGUE_ACTIVE
  LEAGUE_COMPLETE
}

model LeagueMember {
  id        String     @id @default(cuid())
  leagueId  String
  userId    String
  role      MemberRole @default(MEMBER)
  teamId    String?
  league    League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id])
  updatedAt DateTime   @updatedAt

  @@unique([leagueId, userId])
  @@index([teamId])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members LeagueMember[]
  bids    Bid[]
  players Player[]       @relation("SoldToTeam")

  @@unique([leagueId, name])
  @@index([leagueId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Players & Auction ──────────────────────────────────────────────────────

model Player {
  id           String              @id @default(cuid())
  slNo         Int?
  name         String
  position     String?
  country      String              @default("India")
  bowlingStyle String?
  battingStyle String?
  iplTeam      String?
  basePrice    Int
  pot          String
  status       PlayerAuctionStatus @default(QUEUED)
  soldToTeamId String?
  soldToTeam   Team?               @relation("SoldToTeam", fields: [soldToTeamId], references: [id], onDelete: SetNull)
  soldPrice    Int?
  externalId   String?
  leagueId     String
  league       League              @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  bids         Bid[]
  performances PlayerPerformance[]
  tradeItems   TradeItem[]

  @@index([leagueId, pot])
  @@index([leagueId, status])
  @@index([soldToTeamId])
}

enum PlayerAuctionStatus {
  QUEUED
  ACTIVE
  BIDDING_OPEN
  SOLD
  UNSOLD
}

model Bid {
  id        String   @id @default(cuid())
  playerId  String
  userId    String
  leagueId  String
  teamId    String?
  amount    Int
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team?  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([leagueId, playerId])
  @@index([teamId])
}

// ─── Fantasy League (Phase 2) ───────────────────────────────────────────────

model LeagueMatch {
  id              String      @id @default(cuid())
  leagueId        String
  externalMatchId String
  team1           String
  team2           String
  status          MatchStatus @default(UPCOMING)
  matchDate       DateTime?
  updatedAt       DateTime    @updatedAt
  league          League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  performances PlayerPerformance[]

  @@unique([leagueId, externalMatchId])
}

enum MatchStatus {
  UPCOMING
  LIVE
  COMPLETED
}

model PlayerPerformance {
  id            String  @id @default(cuid())
  playerId      String
  matchId       String
  runsScored    Int     @default(0)
  ballsFaced    Int     @default(0)
  fours         Int     @default(0)
  sixes         Int     @default(0)
  wicketsTaken  Int     @default(0)
  oversBowled   Float   @default(0)
  runsConceded  Int     @default(0)
  maidens       Int     @default(0)
  catches       Int     @default(0)
  stumpings     Int     @default(0)
  runOuts       Int     @default(0)
  dotBalls      Int     @default(0)
  strikeRate    Float   @default(0)
  economyRate   Float   @default(0)
  fantasyPoints Float   @default(0)
  /** Added on top of auto-imported fantasy (API or local); preserved across scorecard re-imports. */
  adminFantasyAdjustment Float @default(0)
  isDuck        Boolean @default(false)
  isOut         Boolean @default(false)
  updatedAt     DateTime @updatedAt

  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match  LeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([playerId, matchId])
  @@index([matchId])
}

// ─── Trading (Future) ───────────────────────────────────────────────────────

model Trade {
  id         String      @id @default(cuid())
  leagueId   String
  fromUserId String
  toUserId   String
  status     TradeStatus @default(PROPOSED)
  proposedAt DateTime    @default(now())
  resolvedAt DateTime?
  league     League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  fromUser   User        @relation("TradeFrom", fields: [fromUserId], references: [id])
  toUser     User        @relation("TradeTo", fields: [toUserId], references: [id])

  items TradeItem[]

  @@index([leagueId])
}

enum TradeStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  CANCELLED
}

model TradeItem {
  id        String         @id @default(cuid())
  tradeId   String
  playerId  String
  direction TradeDirection
  trade     Trade          @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  player    Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

enum TradeDirection {
  FROM_PROPOSER
  TO_PROPOSER
}
